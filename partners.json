const csvtojson = csv;

async function updateJSON() {
  let partnersData = { flights: [], packages: [], hotels: [], cruises: [], cars: [] };

  for(const partner of partnerFeeds){
    try {
      const response = await axios.get(partner.url);
      let data = [];

      if(partner.url.endsWith(".csv")){
        data = await csvtojson().fromString(response.data);
      } else {
        data = response.data;
      }

      data.forEach(item => {
        partnersData[partner.type].push({
          name: partner.name,
          destination: item.destination || "Unknown",
          price: item.price || "N/A",
          img: item.img || "https://via.placeholder.com/200x120",
          desc: item.description || ""
        });
      });

    } catch(err){
      console.error(Error fetching ${partner.name}: ${err.message});
    }
  }

  fs.writeFileSync('partners.json', JSON.stringify(partnersData, null, 2));
  console.log('partners.json updated successfully!');
}

updateJSON();
